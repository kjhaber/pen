#compdef claude-devcon
# zsh completion for claude-devcon
# Installed by Homebrew to $(brew --prefix)/share/zsh/site-functions/
# or manually placed in a directory on your $fpath

_claude-devcon() {
  local state

  _arguments \
    '1: :->command' \
    '2: :->container'

  case $state in
    command)
      local -a commands
      commands=(
        'exec:open a shell in a running container'
        'stop:stop and remove a container'
        'list:list all claude-devcon containers'
        'sync-settings:sync host settings.json into ~/.claude-devcon/ (preserves devcon hooks/mcpServers)'
      )
      _describe 'command' commands
      ;;
    container)
      case ${words[2]} in
        stop|exec)
          local -a containers
          containers=( ${(f)"$(claude-devcon list --names-only 2>/dev/null)"} )
          _describe 'container' containers
          ;;
      esac
      ;;
  esac
}

_claude-devcon "$@"
