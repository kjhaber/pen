#compdef pen
# zsh completion for pen
# Installed by Homebrew to $(brew --prefix)/share/zsh/site-functions/
# or manually placed in a directory on your $fpath

_pen() {
  local state

  _arguments \
    '1: :->command' \
    '2: :->container'

  case $state in
    command)
      local -a commands
      commands=(
        'exec:open a shell in a running container'
        'stop:stop and remove a container'
        'list:list all pen containers'
        'sync-settings:sync host settings.json into ~/.pen/claude/ (preserves pen hooks/mcpServers; claude harness only)'
        'init:initialize pen for this project (interactive wizard)'
        'build:build the project harness image'
      )
      _describe 'command' commands
      ;;
    container)
      case ${words[2]} in
        stop|exec)
          local -a containers
          containers=( ${(f)"$(pen list --names-only 2>/dev/null)"} )
          _describe 'container' containers
          ;;
      esac
      ;;
  esac
}

_pen "$@"
