#!/usr/bin/env bash
# claude-devcon — run Claude Code inside an isolated Docker container
#
# Usage:
#   claude-devcon           start container (if needed) and launch Claude
#   claude-devcon exec      open a shell in the running container for $PWD
#   claude-devcon stop      stop and remove the container for $PWD
#   claude-devcon list      list all claude-devcon containers

IMAGE="${CLAUDE_DEVCON_IMAGE:-claude-devcon:latest}"
CLAUDE_CONFIG="${CLAUDE_DEVCON_CONFIG:-${HOME}/.claude-devcon}"

# Derive a Docker-safe container name from $PWD (lowercase, alphanum/underscore/hyphen only)
container_name() {
  basename "$PWD" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -cs '[:alnum:]_-' '-' \
    | sed 's/-*$//'
}

# Return the main (primary) worktree path for the current git repo
main_worktree() {
  git worktree list 2>/dev/null | head -1 | awk '{print $1}'
}

_ensure_config() {
  if [[ ! -d "$CLAUDE_CONFIG" ]]; then
    echo "Creating devcon Claude config dir: $CLAUDE_CONFIG" >&2
    mkdir -p "$CLAUDE_CONFIG"
    _seed_config
  fi
}

# Seed ~/.claude-devcon from ~/.claude on first creation so auth and preferences
# are inherited without requiring a fresh login or preference setup.
_seed_config() {
  local src="${HOME}/.claude"
  [[ -d "$src" ]] || return 0

  echo "Seeding config from ${src} ..." >&2

  # Preferences
  [[ -f "${src}/settings.json" ]] && cp "${src}/settings.json" "${CLAUDE_CONFIG}/settings.json"

  # Auth sessions
  for d in sessions session-env; do
    [[ -d "${src}/${d}" ]] && cp -r "${src}/${d}" "${CLAUDE_CONFIG}/${d}"
  done

  # Global CLAUDE.md instructions
  [[ -f "${src}/CLAUDE.md" ]] && cp "${src}/CLAUDE.md" "${CLAUDE_CONFIG}/CLAUDE.md"

  echo "Done seeding config." >&2
}

cmd_launch() {
  local name cwd main_wt
  name=$(container_name)
  cwd="$PWD"

  # Already running — exec claude into it
  if docker ps -q --filter "name=^${name}$" 2>/dev/null | grep -q .; then
    exec docker exec -it \
      --user "$(id -u):$(id -g)" \
      -e HOME=/home/devcon \
      -e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}" \
      "$name" claude --dangerously-skip-permissions
  fi

  # Stopped — remove stale container so we recreate it fresh below
  if docker ps -aq --filter "name=^${name}$" 2>/dev/null | grep -q .; then
    echo "Removing stale container: $name" >&2
    docker rm "$name" >/dev/null
  fi

  # Create new container
  _ensure_config

  # Always mount the current worktree at its host path (preserves absolute paths)
  local mount_args=("-v" "${cwd}:${cwd}")

  # If this is a linked worktree, also mount the main repo's .git dir so git works
  if main_wt=$(main_worktree 2>/dev/null) && [[ -n "$main_wt" && "$cwd" != "$main_wt" ]]; then
    mount_args+=("-v" "${main_wt}/.git:${main_wt}/.git")
  fi

  # Mount .gitconfig read-only so git identity works inside the container
  local gitconfig_args=()
  [[ -f "${HOME}/.gitconfig" ]] && gitconfig_args=("-v" "${HOME}/.gitconfig:/home/devcon/.gitconfig:ro")

  if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
    echo "warning: ANTHROPIC_API_KEY is not set" >&2
  fi

  # Start container detached with a long-lived idle process; claude is exec'd in
  docker run -d \
    --name "$name" \
    --label "claude-devcon=true" \
    --label "claude-devcon.worktree=${cwd}" \
    --user "$(id -u):$(id -g)" \
    -e HOME=/home/devcon \
    -e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}" \
    "${mount_args[@]}" \
    "${gitconfig_args[@]}" \
    -v "${CLAUDE_CONFIG}:/home/devcon/.claude" \
    -w "$cwd" \
    "$IMAGE" sleep infinity >/dev/null

  exec docker exec -it \
    --user "$(id -u):$(id -g)" \
    -e HOME=/home/devcon \
    -e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}" \
    "$name" claude --dangerously-skip-permissions
}

cmd_exec() {
  local name
  name=$(container_name)

  if ! docker ps -q --filter "name=^${name}$" 2>/dev/null | grep -q .; then
    echo "error: no running container for '${name}'" >&2
    echo "Run 'claude-devcon' first to start one." >&2
    return 1
  fi

  exec docker exec -it --user "$(id -u):$(id -g)" -e HOME=/home/devcon "$name" bash
}

cmd_stop() {
  local name
  name=$(container_name)

  if docker ps -aq --filter "name=^${name}$" 2>/dev/null | grep -q .; then
    docker rm -f "$name" >/dev/null
    echo "Stopped and removed: $name" >&2
  else
    echo "No container found for: $name" >&2
    return 1
  fi
}

cmd_list() {
  docker ps -a \
    --filter "label=claude-devcon=true" \
    --format "table {{.Names}}\t{{.Label \"claude-devcon.worktree\"}}\t{{.Status}}"
}

# Allow sourcing for unit tests without executing main logic
[[ "${BASH_SOURCE[0]}" != "${0}" ]] && return 0

set -euo pipefail

case "${1:-}" in
  exec)  cmd_exec ;;
  stop)  cmd_stop ;;
  list)  cmd_list ;;
  "")    cmd_launch ;;
  *)     echo "Usage: claude-devcon [exec|stop|list]" >&2; exit 1 ;;
esac
