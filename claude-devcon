#!/usr/bin/env bash
# claude-devcon — run Claude Code inside an isolated Docker container
#
# Usage:
#   claude-devcon                     start container (if needed) and launch Claude
#   claude-devcon exec [name]         open a shell in a running container
#   claude-devcon stop [name]         stop and remove a container
#   claude-devcon list [--names-only] list all claude-devcon containers
#   claude-devcon sync-settings [--yes]  sync host settings.json into ~/.claude-devcon/ (shows diff; --yes skips prompt)

IMAGE="${CLAUDE_DEVCON_IMAGE:-claude-devcon:latest}"
CLAUDE_CONFIG="${CLAUDE_DEVCON_CONFIG:-${HOME}/.claude-devcon}"

# Derive a Docker-safe container name from $PWD (lowercase, alphanum/underscore/hyphen only)
container_name() {
  basename "$PWD" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -cs '[:alnum:]_-' '-' \
    | sed 's/-*$//'
}

# Return the main (primary) worktree path for the current git repo
main_worktree() {
  git worktree list 2>/dev/null | head -1 | awk '{print $1}'
}

# Return true if the named container exists and has the claude-devcon label
_is_devcon_container() {
  local name="$1"
  docker ps -aq \
    --filter "name=^${name}$" \
    --filter "label=claude-devcon=true" \
    2>/dev/null | grep -q .
}

_ensure_config() {
  if [[ ! -d "$CLAUDE_CONFIG" ]]; then
    echo "Creating devcon Claude config dir: $CLAUDE_CONFIG" >&2
    mkdir -p "$CLAUDE_CONFIG"
    _seed_config
  fi
}

# Seed ~/.claude-devcon from ~/.claude on first creation so auth and preferences
# are inherited without requiring a fresh login or preference setup.
_seed_config() {
  local src="${HOME}/.claude"
  [[ -d "$src" ]] || return 0

  echo "Seeding config from ${src} ..." >&2

  # Preferences
  [[ -f "${src}/settings.json" ]] && cp "${src}/settings.json" "${CLAUDE_CONFIG}/settings.json"

  # Auth sessions
  for d in sessions session-env; do
    [[ -d "${src}/${d}" ]] && cp -r "${src}/${d}" "${CLAUDE_CONFIG}/${d}"
  done

  # Global CLAUDE.md instructions (live-mounted at runtime; seed as fallback)
  [[ -f "${src}/CLAUDE.md" ]] && cp "${src}/CLAUDE.md" "${CLAUDE_CONFIG}/CLAUDE.md"

  # Custom commands (live-mounted at runtime; seed as fallback)
  [[ -d "${src}/commands" ]] && cp -r "${src}/commands" "${CLAUDE_CONFIG}/commands"

  echo "Done seeding config." >&2
}

cmd_launch() {
  local name cwd main_wt
  name=$(container_name)
  cwd="$PWD"

  # Already running — exec claude into it
  if docker ps -q --filter "name=^${name}$" 2>/dev/null | grep -q .; then
    exec docker exec -it \
      --user "$(id -u):$(id -g)" \
      -e HOME=/home/devcon \
      -e CLAUDE_CONFIG_DIR=/home/devcon/.claude \
      -e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}" \
      "$name" claude --dangerously-skip-permissions "$@"
  fi

  # Stopped — remove stale container so we recreate it fresh below
  if docker ps -aq --filter "name=^${name}$" 2>/dev/null | grep -q .; then
    echo "Removing stale container: $name" >&2
    docker rm "$name" >/dev/null
  fi

  # Create new container
  _ensure_config

  # Always mount the current worktree at its host path (preserves absolute paths)
  local mount_args=("-v" "${cwd}:${cwd}")

  # Live read-only mounts for shared host content — always current, no staleness
  local live_mount_args=()
  local host_claude="${HOME}/.claude"
  [[ -f "${host_claude}/CLAUDE.md" ]] \
    && live_mount_args+=("-v" "${host_claude}/CLAUDE.md:/home/devcon/.claude/CLAUDE.md:ro")
  [[ -d "${host_claude}/commands" ]] \
    && live_mount_args+=("-v" "${host_claude}/commands:/home/devcon/.claude/commands:ro")

  # If this is a linked worktree, also mount the main repo's .git dir so git works
  if main_wt=$(main_worktree 2>/dev/null) && [[ -n "$main_wt" && "$cwd" != "$main_wt" ]]; then
    mount_args+=("-v" "${main_wt}/.git:${main_wt}/.git")
  fi

  # Mount .gitconfig read-only so git identity works inside the container
  local gitconfig_args=()
  [[ -f "${HOME}/.gitconfig" ]] && gitconfig_args=("-v" "${HOME}/.gitconfig:/home/devcon/.gitconfig:ro")

  if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
    echo "warning: ANTHROPIC_API_KEY is not set" >&2
  fi

  # Start container detached with a long-lived idle process; claude is exec'd in
  docker run -d \
    --name "$name" \
    --label "claude-devcon=true" \
    --label "claude-devcon.worktree=${cwd}" \
    --user "$(id -u):$(id -g)" \
    -e HOME=/home/devcon \
    -e CLAUDE_CONFIG_DIR=/home/devcon/.claude \
    -e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}" \
    "${mount_args[@]}" \
    "${gitconfig_args[@]}" \
    -v "${CLAUDE_CONFIG}:/home/devcon/.claude" \
    "${live_mount_args[@]}" \
    -w "$cwd" \
    "$IMAGE" sleep infinity >/dev/null

  exec docker exec -it \
    --user "$(id -u):$(id -g)" \
    -e HOME=/home/devcon \
    -e CLAUDE_CONFIG_DIR=/home/devcon/.claude \
    -e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}" \
    "$name" claude --dangerously-skip-permissions "$@"
}

cmd_sync() {
  local yes=false
  [[ "${1:-}" == "--yes" || "${1:-}" == "-y" ]] && yes=true

  local src="${HOME}/.claude/settings.json"
  local dst="${CLAUDE_CONFIG}/settings.json"

  if [[ ! -f "$src" ]]; then
    echo "error: No source settings found at ${src}" >&2
    return 1
  fi

  if ! command -v jq &>/dev/null; then
    echo "error: jq is required for sync-settings" >&2
    return 1
  fi

  _ensure_config

  # Compute the merged result
  local tmp
  tmp=$(mktemp)
  if [[ ! -f "$dst" ]]; then
    jq 'del(.hooks, .mcpServers) + {skipDangerousModePermissionPrompt: true}' "$src" > "$tmp"
  else
    jq -s '
      .[0] as $src | .[1] as $dst |
      ($src | del(.hooks, .mcpServers))
      + (if $dst.hooks then {hooks: $dst.hooks} else {} end)
      + (if $dst.mcpServers then {mcpServers: $dst.mcpServers} else {} end)
      + {skipDangerousModePermissionPrompt: true}
    ' "$src" "$dst" > "$tmp"
  fi

  # Already in sync?
  if [[ -f "$dst" ]] && diff -q "$dst" "$tmp" >/dev/null 2>&1; then
    echo "Settings already in sync, no changes needed." >&2
    rm -f "$tmp"
    return 0
  fi

  # Show preview
  echo "Changes to ${dst}:" >&2
  if [[ -f "$dst" ]]; then
    diff "$dst" "$tmp" || true
  else
    echo "(new file)" >&2
    cat "$tmp"
  fi

  # Apply
  if $yes; then
    mv "$tmp" "$dst"
    echo "Settings synced." >&2
  elif [[ -t 0 ]]; then
    printf '\nApply these changes? [y/N] '
    local response
    read -r response
    if [[ "$response" =~ ^[Yy]$ ]]; then
      mv "$tmp" "$dst"
      echo "Settings synced." >&2
    else
      rm -f "$tmp"
      echo "Aborted." >&2
      return 1
    fi
  else
    rm -f "$tmp"
    echo "Run with --yes to apply." >&2
    return 1
  fi
}

cmd_exec() {
  local name
  if [[ -n "${1:-}" ]]; then
    name="$1"
    if ! _is_devcon_container "$name"; then
      echo "error: '${name}' is not a claude-devcon container" >&2
      return 1
    fi
  else
    name=$(container_name)
  fi

  if ! docker ps -q --filter "name=^${name}$" 2>/dev/null | grep -q .; then
    echo "error: no running container for '${name}'" >&2
    echo "Run 'claude-devcon' first to start one." >&2
    return 1
  fi

  exec docker exec -it --user "$(id -u):$(id -g)" -e HOME=/home/devcon "$name" bash
}

cmd_stop() {
  local name
  if [[ -n "${1:-}" ]]; then
    name="$1"
    if ! _is_devcon_container "$name"; then
      echo "error: '${name}' is not a claude-devcon container" >&2
      return 1
    fi
  else
    name=$(container_name)
  fi

  if docker ps -aq --filter "name=^${name}$" 2>/dev/null | grep -q .; then
    docker rm -f "$name" >/dev/null
    echo "Stopped and removed: $name" >&2
  else
    echo "No container found for: $name" >&2
    return 1
  fi
}

cmd_list() {
  if [[ "${1:-}" == "--names-only" ]]; then
    docker ps -a \
      --filter "label=claude-devcon=true" \
      --format "{{.Names}}"
    return
  fi
  docker ps -a \
    --filter "label=claude-devcon=true" \
    --format "table {{.Names}}\t{{.Label \"claude-devcon.worktree\"}}\t{{.Status}}"
}

# Allow sourcing for unit tests without executing main logic
[[ "${BASH_SOURCE[0]}" != "${0}" ]] && return 0

set -euo pipefail

case "${1:-}" in
  exec)          cmd_exec "${2:-}" ;;
  stop)          cmd_stop "${2:-}" ;;
  list)          cmd_list "${2:-}" ;;
  sync-settings) cmd_sync ;;
  *)             cmd_launch "$@" ;;
esac
