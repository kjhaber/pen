#!/usr/bin/env bash
# pen — run a coding harness inside an isolated Docker container
#
# Usage:
#   pen [--harness=<name>]                       start container (if needed) and launch harness
#   pen [--harness=<name>] exec [container]      open a shell in a running container
#   pen [--harness=<name>] stop [container]      stop and remove a container
#   pen [--harness=<name>] list [--names-only]   list all pen containers
#   pen [--harness=<name>] sync-settings [--yes] sync host settings into pen config (claude only)
#   pen [--harness=<name>] build                 build the project harness image
#   pen init [--yes] [--force] [--image=<img>]   initialize pen for this project (wizard)
#   pen -- <args>                                pass args directly to harness (bypass pen flag parsing)
#   pen --help | -h                              show this help text
#   pen --version | -V                           show pen version
#
# Harness selection (highest to lowest priority):
#   --harness=<name>                    CLI flag
#   .pen.toml (main worktree)           harness = "name"
#   ~/.pen/config.toml                  harness = "name"
#   default: claude
#
# Image selection (highest to lowest priority):
#   PEN_IMAGE env var
#   .pen.toml (main worktree)           image = "registry/image:tag"
#   ~/.pen/config.toml                  image = "registry/image:tag"
#   default: pen-<harness>:latest

PEN_VERSION="%%VERSION%%"

# ---------------------------------------------------------------------------
# TOML parsing (simple key = "value" only — no sections)
# ---------------------------------------------------------------------------

_read_toml_str() {
  local file="$1" key="$2"
  grep -m1 "^${key}[[:space:]]*=" "$file" 2>/dev/null \
    | sed 's/.*=[[:space:]]*"\(.*\)".*/\1/'
}

# ---------------------------------------------------------------------------
# Harness resolution
# ---------------------------------------------------------------------------

resolve_harness() {
  # 1. CLI flag
  [[ -n "${CLI_HARNESS:-}" ]] && { echo "$CLI_HARNESS"; return; }

  # 2. .pen.toml in main worktree (applies from any linked worktree too)
  local root
  root=$(main_worktree 2>/dev/null || true)
  if [[ -n "$root" && -f "$root/.pen.toml" ]]; then
    local h; h=$(_read_toml_str "$root/.pen.toml" harness)
    [[ -n "$h" ]] && { echo "$h"; return; }
  fi

  # 3. ~/.pen/config.toml user default
  if [[ -f "${HOME}/.pen/config.toml" ]]; then
    local h; h=$(_read_toml_str "${HOME}/.pen/config.toml" harness)
    [[ -n "$h" ]] && { echo "$h"; return; }
  fi

  # 4. Default
  echo "claude"
}

# ---------------------------------------------------------------------------
# Image resolution
# ---------------------------------------------------------------------------

_resolve_image() {
  local default="$1"

  local root
  root=$(main_worktree 2>/dev/null || true)
  if [[ -n "$root" && -f "${root}/.pen.toml" ]]; then
    local img; img=$(_read_toml_str "${root}/.pen.toml" image)
    [[ -n "$img" ]] && { echo "$img"; return; }
  fi

  if [[ -f "${HOME}/.pen/config.toml" ]]; then
    local img; img=$(_read_toml_str "${HOME}/.pen/config.toml" image)
    [[ -n "$img" ]] && { echo "$img"; return; }
  fi

  echo "$default"
}

# ---------------------------------------------------------------------------
# Harness configuration — sets globals used by all commands
# ---------------------------------------------------------------------------

# Sets: HARNESS_IMAGE, HARNESS_CONFIG
# HARNESS_CONFIG is the same path on host and container (mirrored mount).
# Derived from it: pen_shared_rw=$(dirname HARNESS_CONFIG), pen_shared_ro=sibling ro/
configure_harness() {
  case "${HARNESS:-}" in
    claude)
      HARNESS_IMAGE="${PEN_IMAGE:-$(_resolve_image "pen-claude:latest")}"
      HARNESS_CONFIG="${HOME}/.pen/container-shared/rw/claude"
      ;;
    cursor)
      HARNESS_IMAGE="${PEN_IMAGE:-$(_resolve_image "pen-cursor:latest")}"
      HARNESS_CONFIG="${HOME}/.pen/container-shared/rw/cursor"
      ;;
    opencode)
      echo "error: ${HARNESS} harness is not yet implemented" >&2
      exit 1
      ;;
    *)
      echo "error: unknown harness '${HARNESS:-}'. Known harnesses: claude, cursor" >&2
      exit 1
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Project init helpers
# ---------------------------------------------------------------------------

# Detect language runtimes from project files; echoes space-separated apk package names
_detect_stack() {
  local root="$1"
  local pkgs=()
  [[ -f "${root}/go.mod" || -f "${root}/go.sum" ]] \
    && pkgs+=(go)
  [[ -f "${root}/requirements.txt" || -f "${root}/setup.py" \
     || -f "${root}/pyproject.toml" || -f "${root}/Pipfile" ]] \
    && pkgs+=(python3)
  [[ -f "${root}/pom.xml" || -f "${root}/build.gradle" \
     || -f "${root}/build.gradle.kts" ]] \
    && pkgs+=(openjdk21)
  [[ -f "${root}/Gemfile" ]] \
    && pkgs+=(ruby)
  [[ -f "${root}/Cargo.toml" ]] \
    && pkgs+=(rust cargo)
  echo "${pkgs[*]}"
}

# Write a project Dockerfile to stdout
_gen_project_dockerfile() {
  local harness="$1" base_image="$2" packages="$3"

  local from_image="${base_image}"
  if [[ -z "$from_image" ]]; then
    case "$harness" in
      cursor) from_image="pen-cursor:latest" ;;
      *)      from_image="pen-claude:latest" ;;
    esac
  fi

  printf 'FROM %s\n' "$from_image"

  [[ -z "$packages" ]] && return

  case "$harness" in
    cursor)
      printf '\nRUN apt-get update && apt-get install -y --no-install-recommends %s \\\n' "$packages"
      printf '    && rm -rf /var/lib/apt/lists/*\n'
      ;;
    *)
      printf '\nRUN apk add --no-cache %s\n' "$packages"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Harness-specific helpers
# ---------------------------------------------------------------------------

# Prints one docker flag argument per line for docker run/exec env vars
harness_env_args() {
  case "$HARNESS" in
    claude)
      printf '%s\n' "-e" "CLAUDE_CONFIG_DIR=${HARNESS_CONFIG}"
      printf '%s\n' "-e" "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}"
      ;;
    cursor)
      printf '%s\n' "-e" "CURSOR_CONFIG_DIR=${HARNESS_CONFIG}"
      printf '%s\n' "-e" "CURSOR_DATA_DIR=${HARNESS_CONFIG}"
      printf '%s\n' "-e" "CURSOR_API_KEY=${CURSOR_API_KEY:-}"
      ;;
  esac
}

# Prints one docker flag argument per line for live read-only mounts
harness_live_mount_args() {
  case "$HARNESS" in
    claude)
      local src="${HOME}/.claude"
      if [[ -f "${src}/CLAUDE.md" ]]; then
        printf '%s\n' "-v" "${src}/CLAUDE.md:${HARNESS_CONFIG}/CLAUDE.md:ro"
      fi
      if [[ -d "${src}/commands" ]]; then
        printf '%s\n' "-v" "${src}/commands:${HARNESS_CONFIG}/commands:ro"
      fi
      ;;
    cursor)
      local src="${HOME}/.cursor"
      if [[ -d "${src}/rules" ]]; then
        printf '%s\n' "-v" "${src}/rules:${HARNESS_CONFIG}/rules:ro"
      fi
      ;;
  esac
}

# Runs harness-specific preflight checks; exits on failure
harness_preflight_check() {
  case "$HARNESS" in
    claude)
      local pen_shared_ro
      pen_shared_ro="$(dirname "$(dirname "${HARNESS_CONFIG}")")/ro"
      local guardrails_hook="${pen_shared_ro}/hooks/pen-guardrails.sh"
      if [[ ! -x "$guardrails_hook" ]]; then
        echo "error: guardrails hook not found at ${guardrails_hook}" >&2
        echo "Run 'pen sync-settings' to install it." >&2
        exit 1
      fi
      ;;
  esac
}

# Warns if a required API key is missing
harness_api_key_check() {
  case "$HARNESS" in
    claude)
      [[ -z "${ANTHROPIC_API_KEY:-}" ]] \
        && echo "warning: ANTHROPIC_API_KEY is not set" >&2
      ;;
    cursor)
      [[ -z "${CURSOR_API_KEY:-}" ]] \
        && echo "warning: CURSOR_API_KEY is not set (use agent login in the container if needed)" >&2
      ;;
  esac
}

# Echoes the command + args to exec inside the container
harness_exec_cmd() {
  case "$HARNESS" in
    claude) echo "claude" "--dangerously-skip-permissions" "$@" ;;
    cursor)
      # --force: fewer command-approval prompts; --trust with --print: workspace trust in headless mode
      local trust=()
      local a
      for a in "$@"; do
        if [[ "$a" == "--print" ]]; then
          trust=(--trust)
          break
        fi
      done
      echo "agent" "--force" "${trust[@]}" "$@"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Shared helpers
# ---------------------------------------------------------------------------

# Derive a Docker-safe container name from $PWD (pen_ prefix, lowercase, alphanum/underscore/hyphen)
container_name() {
  local base
  base=$(basename "$PWD" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -cs '[:alnum:]_-' '-' \
    | sed 's/-*$//')
  echo "pen_${base}"
}

# Return the main (primary) worktree path for the current git repo
main_worktree() {
  git worktree list 2>/dev/null | head -1 | awk '{print $1}'
}

# Return true if the named container exists and has the pen label
_is_pen_container() {
  local name="$1"
  docker ps -aq \
    --filter "name=^${name}$" \
    --filter "label=pen=true" \
    2>/dev/null | grep -q .
}

_ensure_config() {
  if [[ ! -d "$HARNESS_CONFIG" ]]; then
    echo "Creating pen config dir: $HARNESS_CONFIG" >&2
    mkdir -p "$HARNESS_CONFIG"
    _seed_config
  fi
}

# Seed harness config from host on first creation so auth and preferences are inherited
_seed_config() {
  case "$HARNESS" in
    claude)
      local src="${HOME}/.claude"
      [[ -d "$src" ]] || return 0
      echo "Seeding config from ${src} ..." >&2
      [[ -f "${src}/settings.json" ]] && cp "${src}/settings.json" "${HARNESS_CONFIG}/settings.json"
      for d in sessions session-env; do
        [[ -d "${src}/${d}" ]] && cp -r "${src}/${d}" "${HARNESS_CONFIG}/${d}"
      done
      [[ -f "${src}/CLAUDE.md" ]] && cp "${src}/CLAUDE.md" "${HARNESS_CONFIG}/CLAUDE.md"
      [[ -d "${src}/commands" ]] && cp -r "${src}/commands" "${HARNESS_CONFIG}/commands"
      echo "Done seeding config." >&2
      ;;
    cursor)
      local src="${HOME}/.cursor"
      [[ -d "$src" ]] || return 0
      echo "Seeding config from ${src} ..." >&2
      local f
      shopt -s nullglob
      for f in "${src}"/*.json; do
        cp "$f" "${HARNESS_CONFIG}/"
      done
      shopt -u nullglob
      [[ -d "${src}/rules" ]] && cp -a "${src}/rules" "${HARNESS_CONFIG}/rules"
      echo "Done seeding config." >&2
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_launch() {
  harness_preflight_check

  local name cwd main_wt
  name=$(container_name)
  cwd="$PWD"

  # Already running — exec harness into it
  if docker ps -q --filter "name=^${name}$" 2>/dev/null | grep -q .; then
    local env_args=()
    while IFS= read -r arg; do [[ -n "$arg" ]] && env_args+=("$arg"); done < <(harness_env_args)
    # shellcheck disable=SC2046
    exec docker exec -it \
      --user "$(id -u):$(id -g)" \
      -e HOME=/home/pen \
      "${env_args[@]}" \
      "$name" $(harness_exec_cmd "$@")
  fi

  # Stopped — remove stale container so we recreate it fresh below
  if docker ps -aq --filter "name=^${name}$" 2>/dev/null | grep -q .; then
    echo "Removing stale container: $name" >&2
    docker rm "$name" >/dev/null
  fi

  _ensure_config
  harness_api_key_check

  # Derive container-shared dirs from HARNESS_CONFIG (same path on host and container)
  local pen_shared_rw pen_shared_ro
  pen_shared_rw="$(dirname "${HARNESS_CONFIG}")"
  pen_shared_ro="$(dirname "${pen_shared_rw}")/ro"

  # Always mount the current worktree at its host path (preserves absolute paths)
  local mount_args=("-v" "${cwd}:${cwd}")

  # Live read-only mounts — always current, no staleness
  local live_mount_args=()
  while IFS= read -r arg; do
    [[ -n "$arg" ]] && live_mount_args+=("$arg")
  done < <(harness_live_mount_args)

  # If linked worktree, also mount the main repo's .git dir
  if main_wt=$(main_worktree 2>/dev/null) && [[ -n "$main_wt" && "$cwd" != "$main_wt" ]]; then
    mount_args+=("-v" "${main_wt}/.git:${main_wt}/.git")
  fi

  # Mount .gitconfig read-only so git identity works inside the container
  local gitconfig_args=()
  [[ -f "${HOME}/.gitconfig" ]] && gitconfig_args=("-v" "${HOME}/.gitconfig:/home/pen/.gitconfig:ro")

  # Collect env args for docker run
  local env_args=()
  while IFS= read -r arg; do
    [[ -n "$arg" ]] && env_args+=("$arg")
  done < <(harness_env_args)

  # Start container detached with a long-lived idle process; harness is exec'd in
  docker run -d \
    --name "$name" \
    --label "pen=true" \
    --label "pen.harness=${HARNESS}" \
    --label "pen.worktree=${cwd}" \
    --user "$(id -u):$(id -g)" \
    -e HOME=/home/pen \
    "${env_args[@]}" \
    "${mount_args[@]}" \
    "${gitconfig_args[@]}" \
    -v "${pen_shared_ro}:${pen_shared_ro}:ro" \
    -v "${pen_shared_rw}:${pen_shared_rw}" \
    "${live_mount_args[@]}" \
    -w "$cwd" \
    "$HARNESS_IMAGE" sleep infinity >/dev/null

  local exec_env_args=()
  while IFS= read -r arg; do [[ -n "$arg" ]] && exec_env_args+=("$arg"); done < <(harness_env_args)
  # shellcheck disable=SC2046
  exec docker exec -it \
    --user "$(id -u):$(id -g)" \
    -e HOME=/home/pen \
    "${exec_env_args[@]}" \
    "$name" $(harness_exec_cmd "$@")
}

cmd_sync() {
  if [[ "${HARNESS:-}" != "claude" ]]; then
    echo "error: sync-settings is only supported for the claude harness" >&2
    return 1
  fi

  local yes=false
  [[ "${1:-}" == "--yes" || "${1:-}" == "-y" ]] && yes=true

  local src="${HOME}/.claude/settings.json"
  local dst="${HARNESS_CONFIG}/settings.json"
  local pen_shared_rw pen_shared_ro hooks_dir guardrails_hook
  pen_shared_rw="$(dirname "${HARNESS_CONFIG}")"
  pen_shared_ro="$(dirname "${pen_shared_rw}")/ro"
  hooks_dir="${pen_shared_ro}/hooks"
  guardrails_hook="${hooks_dir}/pen-guardrails.sh"

  if [[ ! -f "$src" ]]; then
    echo "error: No source settings found at ${src}" >&2
    return 1
  fi

  if ! command -v jq &>/dev/null; then
    echo "error: jq is required for sync-settings" >&2
    return 1
  fi

  _ensure_config
  mkdir -p "$pen_shared_ro" "$pen_shared_rw" "$hooks_dir"

  # Write the guardrails hook script (always up-to-date)
  cat > "$guardrails_hook" << 'GUARDRAILS_EOF'
#!/usr/bin/env bash
# pen-guardrails.sh — PreToolUse hook for pen containers
# Managed by 'pen sync-settings'. Do not edit by hand.
# Receives Claude Code hook event JSON on stdin; exits non-zero to block.

INPUT=$(cat)
TOOL=$(printf '%s' "$INPUT" | jq -r '.tool_name // ""')
[[ "$TOOL" != "Bash" ]] && exit 0

CMD=$(printf '%s' "$INPUT" | jq -r '.tool_input.command // ""')

# Block: gh pr create (drafting with gh pr view/diff is allowed)
if printf '%s' "$CMD" | grep -qE '^\s*gh\s+pr\s+create(\s|$)'; then
  printf 'pen guardrail: gh pr create is blocked. Draft PR description with gh pr view/diff, then create the PR from the host.\n' >&2
  exit 1
fi

# Block: git push --force / -f / --force-with-lease
if printf '%s' "$CMD" | grep -qE '^\s*git\s+push\b' \
  && printf '%s' "$CMD" | grep -qE '(^|\s)(--force|--force-with-lease|-f)(\s|$)'; then
  printf 'pen guardrail: git push --force is blocked.\n' >&2
  exit 1
fi

# Block: git push to protected branches (main, master, develop)
if printf '%s' "$CMD" | grep -qE '^\s*git\s+push\b' \
  && printf '%s' "$CMD" | grep -qE '\b(main|master|develop)\b'; then
  printf 'pen guardrail: pushing to main/master/develop is blocked.\n' >&2
  exit 1
fi

exit 0
GUARDRAILS_EOF
  chmod +x "$guardrails_hook"

  # Compute the merged result
  local tmp dst_json
  tmp=$(mktemp)
  dst_json="{}"
  [[ -f "$dst" ]] && dst_json=$(cat "$dst")

  jq -n \
    --argjson src "$(cat "$src")" \
    --argjson dst "$dst_json" \
    --arg guardrails_hook "$guardrails_hook" \
    '
      ($src | del(.hooks, .mcpServers))
      + (if $dst.mcpServers then {mcpServers: $dst.mcpServers} else {} end)
      + {skipDangerousModePermissionPrompt: true}
      + {
          hooks: (
            ($dst.hooks // {} | del(.PreToolUse))
            + {
                PreToolUse: [
                  {
                    matcher: "Bash",
                    hooks: [
                      {type: "command", command: $guardrails_hook}
                    ]
                  }
                ]
              }
          )
        }
    ' > "$tmp"

  # Already in sync?
  if [[ -f "$dst" ]] && diff -q "$dst" "$tmp" >/dev/null 2>&1; then
    echo "Settings already in sync, no changes needed." >&2
    rm -f "$tmp"
    return 0
  fi

  # Show preview
  echo "Changes to ${dst}:" >&2
  if [[ -f "$dst" ]]; then
    diff "$dst" "$tmp" || true
  else
    echo "(new file)" >&2
    cat "$tmp"
  fi

  # Apply
  if $yes; then
    mv "$tmp" "$dst"
    echo "Settings synced." >&2
  elif [[ -t 0 ]]; then
    printf '\nApply these changes? [y/N] '
    local response
    read -r response
    if [[ "$response" =~ ^[Yy]$ ]]; then
      mv "$tmp" "$dst"
      echo "Settings synced." >&2
    else
      rm -f "$tmp"
      echo "Aborted." >&2
      return 1
    fi
  else
    rm -f "$tmp"
    echo "Run with --yes to apply." >&2
    return 1
  fi
}


cmd_exec() {
  local name
  if [[ -n "${1:-}" ]]; then
    name="$1"
    if ! _is_pen_container "$name"; then
      echo "error: '${name}' is not a pen container" >&2
      return 1
    fi
  else
    name=$(container_name)
  fi

  if ! docker ps -q --filter "name=^${name}$" 2>/dev/null | grep -q .; then
    echo "error: no running container for '${name}'" >&2
    echo "Run 'pen' first to start one." >&2
    return 1
  fi

  exec docker exec -it --user "$(id -u):$(id -g)" -e HOME=/home/pen "$name" bash
}

cmd_stop() {
  local name
  if [[ -n "${1:-}" ]]; then
    name="$1"
    if ! _is_pen_container "$name"; then
      echo "error: '${name}' is not a pen container" >&2
      return 1
    fi
  else
    name=$(container_name)
  fi

  if docker ps -aq --filter "name=^${name}$" 2>/dev/null | grep -q .; then
    docker rm -f "$name" >/dev/null
    echo "Stopped and removed: $name" >&2
  else
    echo "No container found for: $name" >&2
    return 1
  fi
}

cmd_list() {
  if [[ "${1:-}" == "--names-only" ]]; then
    docker ps -a \
      --filter "label=pen=true" \
      --format "{{.Names}}"
    return
  fi
  docker ps -a \
    --filter "label=pen=true" \
    --format "table {{.Names}}\t{{.Label \"pen.harness\"}}\t{{.Label \"pen.worktree\"}}\t{{.Status}}"
}

cmd_init() {
  local yes=false force=false image=""
  for arg in "$@"; do
    case "$arg" in
      --yes|-y)   yes=true ;;
      --force)    force=true ;;
      --image=*)  image="${arg#--image=}" ;;
    esac
  done

  local main_wt
  main_wt=$(main_worktree 2>/dev/null || true)
  if [[ -z "$main_wt" ]]; then
    echo "error: not in a git repository" >&2
    return 1
  fi

  local toml_file="${main_wt}/.pen.toml"
  local pen_dir="${main_wt}/.pen"

  if [[ -f "$toml_file" ]] && ! $force; then
    if $yes; then
      echo "pen init: .pen.toml already exists; use --force to overwrite" >&2
      return 0
    fi
    printf '.pen.toml already exists. Overwrite? [y/N] '
    local r; read -r r
    [[ "$r" =~ ^[Yy]$ ]] || { echo "Aborted." >&2; return 1; }
  fi

  # ---- [1/3] Harness ----
  local harness="${HARNESS:-claude}"
  if ! $yes; then
    printf '\n[1/3] Default harness\n'
    printf '  [1] claude (Claude Code CLI)  [2] cursor (Cursor Agent)\n'
    printf '  Choice [1]: '
    local r; read -r r
    [[ "$r" == "2" ]] && harness="cursor"
  fi

  # ---- [2/3] Docker image ----
  if ! $yes && [[ -z "$image" ]]; then
    printf '\n[2/3] Docker image\n'
    printf '  Default: pen-%s:latest (built locally via pen build)\n' "$harness"
    printf '  Company/custom registry image (leave blank for default): '
    read -r image
  fi

  # ---- [3/3] Additional packages ----
  local detected; detected=$(_detect_stack "$main_wt")
  local packages="$detected"
  if ! $yes; then
    printf '\n[3/3] Additional packages\n'
    if [[ -n "$detected" ]]; then
      printf '  Detected from project: %s\n' "$detected"
    else
      printf '  None auto-detected\n'
    fi
    printf '  Extra packages to add (space-separated, e.g. github-cli kubectl): '
    local extra; read -r extra
    [[ -n "$extra" ]] && packages="${packages:+$packages }${extra}"
  fi

  # Write .pen.toml
  {
    printf 'harness = "%s"\n' "$harness"
    [[ -n "$image" ]] && printf 'image = "%s"\n' "$image"
  } > "$toml_file"
  printf 'Wrote %s\n' "$toml_file" >&2

  # Write project Dockerfile only when packages are needed
  if [[ -n "$packages" ]]; then
    mkdir -p "$pen_dir"
    local dockerfile="${pen_dir}/Dockerfile.${harness}"
    _gen_project_dockerfile "$harness" "$image" "$packages" > "$dockerfile"
    printf 'Wrote %s\n' "$dockerfile" >&2
    printf '\nRun '"'"'pen build'"'"' to build the project image.\n' >&2
  else
    printf '\nNo extra packages — using default pen-%s:latest.\n' "$harness" >&2
  fi
}

cmd_build() {
  local main_wt
  main_wt=$(main_worktree 2>/dev/null || true)
  if [[ -z "$main_wt" ]]; then
    echo "error: not in a git repository" >&2
    return 1
  fi

  # Resolve project Dockerfile from main worktree
  local dockerfile=""
  [[ -f "${main_wt}/.pen/Dockerfile.${HARNESS}" ]] \
    && dockerfile="${main_wt}/.pen/Dockerfile.${HARNESS}"
  [[ -z "$dockerfile" && -f "${main_wt}/.pen/Dockerfile" ]] \
    && dockerfile="${main_wt}/.pen/Dockerfile"

  if [[ -z "$dockerfile" ]]; then
    echo "error: no project Dockerfile found at ${main_wt}/.pen/Dockerfile.${HARNESS}" >&2
    echo "Run 'pen init' to create one." >&2
    return 1
  fi

  echo "Building ${HARNESS} image: ${HARNESS_IMAGE}" >&2
  docker build -t "$HARNESS_IMAGE" "$(dirname "$dockerfile")"
}

cmd_help() {
  sed -n '2,/^PEN_VERSION/s/^# \{0,1\}//p' "${BASH_SOURCE[0]}"
}

cmd_version() {
  local v="$PEN_VERSION"
  if [[ "$v" == "%%VERSION%%" ]]; then
    v=$(git describe --tags --abbrev=0 2>/dev/null || echo "unknown")
  fi
  echo "pen $v"
}

# Allow sourcing for unit tests without executing main logic
[[ "${BASH_SOURCE[0]}" != "${0}" ]] && return 0

set -euo pipefail

# Parse --harness flag; strip it from passthrough args
# '--' stops pen flag parsing; all subsequent args go directly to harness
CLI_HARNESS=""
passthrough_args=()
passthrough_only=false
for arg in "$@"; do
  if $passthrough_only; then
    passthrough_args+=("$arg")
    continue
  fi
  case "$arg" in
    --harness=*) CLI_HARNESS="${arg#--harness=}" ;;
    --)          passthrough_only=true ;;
    *)           passthrough_args+=("$arg") ;;
  esac
done

case "${passthrough_args[0]:-}" in
  --help|-h)     cmd_help; exit 0 ;;
  --version|-V)  cmd_version; exit 0 ;;
  *) ;;
esac

HARNESS=$(resolve_harness)
configure_harness

case "${passthrough_args[0]:-}" in
  exec)          cmd_exec "${passthrough_args[1]:-}" ;;
  stop)          cmd_stop "${passthrough_args[1]:-}" ;;
  list)          cmd_list "${passthrough_args[1]:-}" ;;
  sync-settings) cmd_sync "${passthrough_args[@]:1}" ;;
  init)          cmd_init "${passthrough_args[@]:1}" ;;
  build)         cmd_build "${passthrough_args[@]:1}" ;;
  *)             cmd_launch "${passthrough_args[@]}" ;;
esac
